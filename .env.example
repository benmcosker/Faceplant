# Faceplant backend config. Copy to faceplant/.env and fill in real values.

DATABASE_URL=postgresql+psycopg://faceplant:faceplant@localhost:5433/faceplant
FRONTEND_URL=http://localhost:5174

# Relative to the directory uvicorn is run from (faceplant/backend).
MEDIA_ROOT=./uploads
MAX_AVATAR_MB=5

# Shared secret for the admin-only bot-construction endpoints (X-Admin-Key header).
ADMIN_API_KEY=generate-a-random-secret

# Anthropic API key, used to generate in-persona bot reactions.
ANTHROPIC_API_KEY=your-anthropic-api-key
DEFAULT_BOT_MODEL=claude-haiku-4-5

# Giphy API key, used by GIF-first bot personas (e.g. gifgremlin) to fetch a
# random reaction GIF by tag. Optional — without it those bots reply with a
# caption only. Get one at https://developers.giphy.com/.
GIPHY_API_KEY=your-giphy-api-key

# How a human's new post gets swarmed: short wave first, long wave later.
SHORT_REACTION_WINDOW_MINUTES=5
LONG_REACTION_WINDOW_MIN_MINUTES=15
LONG_REACTION_WINDOW_MAX_MINUTES=180
SHORT_WAVE_SIZE_MIN=3
SHORT_WAVE_SIZE_MAX=5
LONG_WAVE_SIZE_MIN=3
LONG_WAVE_SIZE_MAX=5
